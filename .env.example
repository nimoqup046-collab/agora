# =============================================================================
# AGORA — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your .env file.
# =============================================================================

# AI Model API Keys（三选一，优先级：OpenRouter > DeepSeek > Anthropic/OpenAI）
#
# 推荐：OpenRouter（一个 key 调所有模型，国内可访问）
#   注册：https://openrouter.ai
OPENROUTER_API_KEY=
#
# 备选：DeepSeek（国内可访问，便宜）
#   注册：https://platform.deepseek.com
DEEPSEEK_API_KEY=
#
# 海外：直连 Anthropic + OpenAI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# 使用 OpenRouter 时的模型名（可按需换）
# 完整模型列表：https://openrouter.ai/models
DEFAULT_MODEL_CLAUDE=anthropic/claude-opus-4
DEFAULT_MODEL_CODEX=openai/gpt-4o
DEFAULT_MODEL_META=anthropic/claude-sonnet-4-5

# Token budget per agent per turn
MAX_TOKENS_PER_TURN=4096

# PostgreSQL + pgvector (required)
DATABASE_URL=postgresql://agora:changeme_in_production@localhost:5432/agora

# Redis (required)
REDIS_URL=redis://localhost:6379

# API Service
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# Web Service
NEXT_PUBLIC_API_URL=http://localhost:8000

# GitHub Integration (optional — needed for /act/confirm PR creation)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_DEFAULT_OWNER=your_github_org_or_username
GITHUB_DEFAULT_REPO=your_repo_name

# Observability
LOG_LEVEL=info
