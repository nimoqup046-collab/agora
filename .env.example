# =============================================================================
# AGORA Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your .env file.
# =============================================================================

# Provider selection
#   auto | openrouter | zhipu | deepseek | anthropic_openai
# In auto mode, priority is: OpenRouter > Zhipu > DeepSeek > Anthropic/OpenAI
LLM_PROVIDER=auto

# Model provider API keys (you can configure multiple)
OPENROUTER_API_KEY=
ZHIPU_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model names used by AGORA agents
# DeepSeek examples: deepseek-chat
# Zhipu examples: glm-4-flash / glm-4-plus
# OpenRouter examples: anthropic/claude-sonnet-4-5, openai/gpt-4o-mini
DEFAULT_MODEL_CLAUDE=deepseek-chat
DEFAULT_MODEL_CODEX=deepseek-chat
DEFAULT_MODEL_META=deepseek-chat

# Token budget per agent per turn
MAX_TOKENS_PER_TURN=4096

# PostgreSQL + pgvector (required)
DATABASE_URL=postgresql://agora:changeme_in_production@localhost:5432/agora

# Redis (required)
REDIS_URL=redis://localhost:6379

# API Service
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# Web Service
NEXT_PUBLIC_API_URL=http://localhost:8000

# GitHub Integration (optional; needed for /act/confirm PR creation)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_DEFAULT_OWNER=your_github_org_or_username
GITHUB_DEFAULT_REPO=your_repo_name

# Observability
LOG_LEVEL=info