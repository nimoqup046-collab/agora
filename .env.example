# =============================================================================
# AGORA — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your .env file.
# =============================================================================

# AI Model API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Default models per provider
CLAUDE_MODEL=claude-opus-4-5
CODEX_MODEL=gpt-4o
GEMINI_MODEL=gemini-1.5-pro

# Token budget per agent per turn
MAX_TOKENS_PER_TURN=4096
MAX_TOKENS_PER_SESSION=100000

# PostgreSQL + pgvector (Episodic Memory)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agora
POSTGRES_USER=agora
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql://agora:changeme_in_production@localhost:5432/agora

# Redis (Working Memory + Task Queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379
REDIS_SESSION_TTL=86400

# Neo4j (Knowledge Graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme_in_production

# API Service (FastAPI)
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=generate_a_random_secret_key_here
API_CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development

# Web Service (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# GitHub Integration
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# Science APIs (Phase 2+)
SEMANTIC_SCHOLAR_API_KEY=
WOLFRAM_APP_ID=
PUBMED_API_KEY=

# Evolution Engine (Phase 2+)
EVOLUTION_ENABLED=false
EVOLUTION_MIN_SESSIONS_BEFORE_UPDATE=10
EVOLUTION_SAFETY_AUDIT=true
EVOLUTION_MAX_STRATEGY_DRIFT=0.15

# Observability
LOG_LEVEL=info
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

---